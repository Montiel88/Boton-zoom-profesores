# Configuración de Base de Datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zoom_monitor
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# Credenciales de Zoom (OAuth Server-to-Server)
ZOOM_ACCOUNT_ID=tu_account_id
ZOOM_CLIENT_ID=tu_client_id
ZOOM_CLIENT_SECRET=tu_client_secret

# Webhook Secret (para verificar autenticidad)
ZOOM_WEBHOOK_SECRET=tu_webhook_secret

# Brightspace (opcional - para integración con LMS)
BRIGHTSPACE_CLIENT_ID=
BRIGHTSPACE_CLIENT_SECRET=
BRIGHTSPACE_API_BASE=
BRIGHTSPACE_API_VERSION=
